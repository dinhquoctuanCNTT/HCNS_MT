{
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "stylelint.snippet": ["css", "scss"],
  "editor.codeActionsOnSave": {
    "source.fixAll.stylelint": "explicit"
  },
  "css.lint.unknownVendorSpecificProperties": "ignore",
  "[css]": {
    "editor.defaultFormatter": "stylelint.vscode-stylelint"
  }
}
